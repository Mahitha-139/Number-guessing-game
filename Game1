import random

def play_guessing_game():
    print("====================================")
    print("🎯 WELCOME TO THE NUMBER GUESSING GAME! 🎯")
    print("====================================")
    print("I am thinking of a number between 1 and 100.")
    
    # Generate a random secret number between 1 and 100
    secret_number = random.randint(1, 100)
    attempts = 0
    max_attempts = 10
    
    print(f"You have {max_attempts} attempts to get it right. Good luck!\n")
    
    # Main game loop
    while attempts < max_attempts:
        try:
            # Get the user's guess and convert it to an integer
            user_input = input(f"Attempt {attempts + 1}/{max_attempts} | Enter your guess: ")
            guess = int(user_input)
            
            # Bound check validation
            if guess < 1 or guess > 100:
                print("❌ Out of bounds! Please guess a number between 1 and 100.")
                continue
                
            attempts += 1
            
            # Check the user's guess against the secret number
            if guess == secret_number:
                print(f"\n🎉 CONGRATULATIONS! You guessed the secret number {secret_number} correctly!")
                print(f"🏆 It took you {attempts} attempts.")
                break
            elif guess < secret_number:
                print("📉 Too low! Try a higher number.\n")
            else:
                print("📈 Too high! Try a lower number.\n")
                
        except ValueError:
            # Handle cases where the input is not a valid number
            print("⚠️ Invalid input! Please enter a whole number (e.g., 42).\n")
            
    else:
        # This executes if the loop finishes naturally without breaking
        print("\n💀 GAME OVER!")
        print(f"You ran out of attempts. The correct number was {secret_number}.")
        print("Better luck next time!")

if __name__ == "__main__":
    play_guessing_game()
